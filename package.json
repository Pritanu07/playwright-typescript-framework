{
  "name": "pom-saucedemo",
  "version": "1.0.0",
  "scripts": {
    "test:smoke": "playwright test --project=smoke",
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:chromium": "playwright test --project=chromium",
    "test:ui-api": "npx playwright test",
    "test:postman": "newman run postman/collection.json",
    "test:all": "npm run test:ui-api && npm run test:postman",
    "install:browsers": "playwright install",
    "report:allure": "allure generate allure-results --clean -o allure-report",
    "open:allure": "allure open allure-report",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "postman:test": "node postman/scripts/run-postman.js"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "allure-playwright": "^3.9.0",
    "newman": "^6.2.2",
    "newman-reporter-htmlextra": "^1.23.1"
  },
