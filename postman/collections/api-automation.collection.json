{
  "info": {
    "name": "api-automation Collection (JSONPlaceholder)",
    "_postman_id": "a1b2c3d4-5678-90ab-cdef-1234567890ab",
    "description": "Stable API tests for JSONPlaceholder + Newman CI",
    "schema": "https://schema.getpostman.com/json/collections/v2.1.0/collection.json"
  },

  "variable": [
    {
      "key": "baseUrl",
      "value": "https://jsonplaceholder.typicode.com"
    }
  ],

  "item": [

    {
      "name": "Get Users",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/users",
          "host": ["{{baseUrl}}"],
          "path": ["users"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "let jsonData;",
              "",
              "try {",
              "    jsonData = pm.response.json();",
              "} catch (e) {",
              "    console.log('Response is not valid JSON:', pm.response.text());",
              "    pm.expect.fail('Invalid JSON response');",
              "}",
              "",
              "pm.test('Response is array', function () {",
              "    pm.expect(Array.isArray(jsonData)).to.be.true;",
              "});",
              "",
              "pm.test('Users list is not empty', function () {",
              "    pm.expect(jsonData.length).to.be.greaterThan(0);",
              "});"
            ]
          }
        }
      ]
    },

    {
      "name": "Create Post",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"test login\",\n  \"body\": \"qa automation\",\n  \"userId\": 1\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/posts",
          "host": ["{{baseUrl}}"],
          "path": ["posts"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 201', function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "let jsonData = pm.response.json();",
              "",
              "pm.test('Post ID exists', function () {",
              "    pm.expect(jsonData.id).to.exist;",
              "});",
              "",
              "pm.test('Title is correct', function () {",
              "    pm.expect(jsonData.title).to.eql('test login');",
              "});"
            ]
          }
        }
      ]
    }

  ]
}