{
  "info": {
    "name": "api-automation Collection (ReqRes)",
    "_postman_id": "a1b2c3d4-5678-90ab-cdef-1234567890ab",
    "description": "Working API tests for Postman + Newman",
    "schema": "https://schema.getpostman.com/json/collections/v2.1.0/collection.json"
  },

  "variable": [
    {
      "key": "baseUrl",
      "value": "https://reqres.in/api"
    }
  ],

  "item": [
    {
      "name": "Login API",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/login",
          "host": ["{{baseUrl}}"],
          "path": ["login"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"eve.holt@reqres.in\",\n  \"password\": \"cityslicka\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "const jsonData = pm.response.json();",
              "",
              "pm.test('Token exists', function () {",
              "    pm.expect(jsonData.token).to.exist;",
              "    pm.expect(jsonData.token).to.be.a('string');",
              "    pm.expect(jsonData.token.length).to.be.greaterThan(0);",
              "});"
            ]
          }
        }
      ]
    },

    {
      "name": "Get Users",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/users?page=2",
          "host": ["{{baseUrl}}"],
          "path": ["users"],
          "query": [
            {
              "key": "page",
              "value": "2"
            }
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "const jsonData = pm.response.json();",
              "",
              "pm.test('Response structure valid', function () {",
              "    pm.expect(jsonData).to.have.property('data');",
              "    pm.expect(jsonData.data).to.be.an('array');",
              "});",
              "",
              "pm.test('Data not empty', function () {",
              "    pm.expect(jsonData.data.length).to.be.greaterThan(0);",
              "});"
            ]
          }
        }
      ]
    }
  ]
}